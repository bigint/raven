# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/raven

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=changeme-at-least-16-chars
APP_URL=http://localhost:3000

# App
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000

# Encryption (for provider API keys at rest)
ENCRYPTION_SECRET=changeme-at-least-32-bytes-long!!

# Optional: Key rotation
# ENCRYPTION_SECRET_PREVIOUS=
