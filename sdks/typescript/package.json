{
  "name": "@raven-gateway/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Raven AI Gateway",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "keywords": ["ai", "gateway", "openai", "anthropic", "llm", "sdk"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigint-studio/raven",
    "directory": "sdks/typescript"
  }
}
