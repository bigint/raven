{
  "bugs": {
    "url": "https://github.com/bigint/raven/issues"
  },
  "description": "Open-source AI gateway for routing, managing, and observing LLM API traffic",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "drizzle-orm": "^0.45.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/bigint/raven",
  "keywords": [
    "ai-gateway",
    "llm",
    "openai",
    "anthropic",
    "proxy",
    "typescript",
    "open-source",
    "ai",
    "routing",
    "observability"
  ],
  "license": "MIT",
  "name": "raven",
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/bigint/raven.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @raven/db generate",
    "db:migrate": "pnpm --filter @raven/db migrate",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "db:studio": "pnpm --filter @raven/db studio",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @raven/api dev",
    "dev:cron": "pnpm --filter @raven/cron dev",
    "dev:docs": "pnpm --filter @raven/docs dev",
    "dev:web": "pnpm --filter @raven/web dev",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "type": "module"
}
