{
  "name": "@raven/cron",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' tsx watch --env-file=../../.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bigrag/client": "^0.0.6",
    "@paralleldrive/cuid2": "^3.3.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@raven/config": "workspace:*",
    "@raven/db": "workspace:*",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
