      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "getting-started/quickstart",
              "getting-started/concepts"
            ]
          },
          {
            "group": "Self-Hosting",
            "pages": [
              "guides/self-hosting"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/providers",
              "features/virtual-keys",
              "features/models",
              "features/routing-rules",
              "features/chat"
            ]
          },
          {
            "group": "Governance & Safety",
            "pages": [
              "features/guardrails",
              "features/audit-logs"
            ]
          },
          {
            "group": "Cost Management",
            "pages": [
              "features/budgets",
              "features/analytics"
            ]
          },
          {
            "group": "Advanced Features",
            "pages": [
              "features/webhooks"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/overview",
              "security/rate-limiting",
              "security/prompt-injection"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/openai-compatibility",
              "guides/vercel-ai-sdk",
              "guides/streaming",
              "guides/sdk"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Chat Completions",
            "pages": [
              "api-reference/endpoints/chat-completions"
            ]
          }
