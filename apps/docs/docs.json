{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Raven Docs",
  "colors": {
    "primary": "#171717",
    "light": "#737373",
    "dark": "#FFFFFF"
  },
  "appearance": {
    "default": "dark",
    "strict": true,
    "background": {
      "color": {
        "light": "#FFFFFF",
        "dark": "#0A0A0A"
      }
    }
  },
  "favicon": "/favicon.svg",
