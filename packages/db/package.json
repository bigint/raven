{
  "name": "@raven/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/migrate.mjs --bundle --platform=node --format=esm --outfile=dist/migrate.mjs",
    "generate": "set -a && . ../../.env && set +a && drizzle-kit generate",
    "migrate": "set -a && . ../../.env && set +a && drizzle-kit migrate",
    "studio": "set -a && . ../../.env && set +a && drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
